PORT=3200
MEDIASOUP_LISTEN_IP=0.0.0.0
# IP in ICE candidates sent to Telegram clients.
# For Telegram Desktop on the same PC: 127.0.0.1 (or PILTOVER_LOCAL=1).
# For LAN/mobile clients: your LAN IP (e.g. 192.168.0.22).
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
# PILTOVER_LOCAL=1
RTC_MIN_PORT=10000
RTC_MAX_PORT=10100
LOG_LEVEL=info
# Piltover speaking callback (UpdateGroupCallParticipants active_date).
PILTOVER_CALLBACK_URL=http://127.0.0.1:4431/api/group-call-speaking